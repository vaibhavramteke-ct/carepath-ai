# Copy to .env and fill in to enable the LLM-powered agent path.
# Leave ANTHROPIC_API_KEY empty/unset to run the backend in rule-based mode.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
APP_NAME=CarePath AI
EMERGENCY_NUMBER=112

# Persistence. Defaults to a local SQLite file; only this needs to change to
# move to another database (e.g. postgresql+psycopg://user:pass@host/dbname).
DATABASE_URL=sqlite:///./carepath.db
